---
import { fetchVelog } from '../lib/fetchFeeds.ts';

// Velog 사용자 이름 설정 (본인의 아이디로 변경하세요)
const VELOG_USERNAME = '@ds12892'; 
const posts = await fetchVelog(VELOG_USERNAME);
---
<section id="blog" class="min-h-screen flex items-center border-t border-border">
  <div class="max-w-5xl mx-auto px-6 md:px-8 py-16 md:py-24 w-full">
    <div class="text-center mb-12 md:mb-16">
      <h2 class="text-2xl md:text-3xl text-foreground mb-2" style={{ fontFamily: 'var(--font-heading)' }}>Blog Posts</h2>
      <p class="text-sm md:text-base text-muted-foreground">개발 경험과 기술에 대한 생각을 공유합니다</p>
    </div>
    
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
      {posts.map((post) => (
        <article class="border border-border bg-card hover:border-muted-foreground transition-colors">
          <a href={post.link} target="_blank" rel="noopener noreferrer" class="block h-full">
            {/* Thumbnail */}
            {post.thumbnail ? (
              <img src={post.thumbnail} alt={post.title} class="aspect-video w-full object-cover" />
            ) : (
              <img src="/velog-placeholder.png" alt="No Image" class="aspect-video w-full object-cover" />
            )}
          
            <div class="p-5 md:p-6 space-y-3 text-center">
              <p class="text-xs md:text-sm text-muted-foreground">{post.date}</p>
              <h3 class="text-lg md:text-xl text-card-foreground line-clamp-2">{post.title}</h3>
              <p class="text-sm text-muted-foreground leading-relaxed line-clamp-3">{post.excerpt}</p>
              <span class="text-sm text-primary hover:text-primary/80 pt-2 transition-colors inline-block">
                Read more →
              </span>
            </div>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>